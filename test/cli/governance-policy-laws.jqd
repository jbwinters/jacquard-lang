; GM.4: separately discoverable, hermetic Warp laws for the pure governance
; membrane.  Exhaustive mode enumerates every finite generator combination;
; sampled mode provides the ordinary fast governance lane.

(defterm
  ((binding gm4.risk-of-index ()
    (lam ((pvar n))
      (match (var n)
        (clause (plit 0) (var low))
        (clause (plit 1) (var medium))
        (clause (plit 2) (var high))
        (clause (pwild) (var forbidden)))))
   (binding gm4.confidence-of-index ()
    (lam ((pvar n))
      (match (var n)
        (clause (plit 0) (lit 0.0))
        (clause (plit 1) (lit 0.25))
        (clause (plit 2) (lit 0.5))
        (clause (plit 3) (lit 0.75))
        (clause (pwild) (lit 1.0)))))
   (binding gm4.thresholds-of-index ()
    (lam ((pvar n))
      (match (var n)
        (clause (plit 0) (tuple (var low) (var low)))
        (clause (plit 1) (tuple (var low) (var medium)))
        (clause (plit 2) (tuple (var low) (var high)))
        (clause (plit 3) (tuple (var low) (var forbidden)))
        (clause (plit 4) (tuple (var medium) (var medium)))
        (clause (plit 5) (tuple (var medium) (var high)))
        (clause (plit 6) (tuple (var medium) (var forbidden)))
        (clause (plit 7) (tuple (var high) (var high)))
        (clause (plit 8) (tuple (var high) (var forbidden)))
        (clause (pwild) (tuple (var forbidden) (var forbidden))))))
   (binding gm4.live-policy ()
    (lam ((pvar policy-index) (pvar confidence-index))
      (match (app (var gm4.thresholds-of-index) (var policy-index))
        (clause (ptuple (pvar auto) (pvar ask-risk))
          (app (var live-policy-v0) (var governance-v0) (var auto)
            (var ask-risk)
            (app (var gm4.confidence-of-index) (var confidence-index)))))))
   (binding gm4.dry-policy ()
    (lam ((pvar confidence-index))
      (app (var dry-policy-v0) (var governance-v0)
        (app (var gm4.confidence-of-index) (var confidence-index)))))
   (binding gm4.verdict-rank ()
    (lam ((pvar value))
      (match (var value)
        (clause (pcon block) (lit 0))
        (clause (pcon ask) (lit 1))
        (clause (pcon simulate) (lit 1))
        (clause (pcon allow) (lit 2)))))
   (binding gm4.is-allow? ()
    (lam ((pvar value))
      (match (var value)
        (clause (pcon allow) (var true))
        (clause (pwild) (var false)))))
   (binding gm4.policy-hash ()
    (lam ((pvar policy))
      (app (var code.hash) (app (var governance.live-policy-code) (var policy)))))
   (binding gm4.policy-label ()
    (lam ((pvar policy))
      (match (var policy)
        (clause
          (pcon live-policy-v0 (pwild) (pvar auto) (pvar ask-risk)
            (pvar confidence))
          (app (var text.join)
            (lit "policy={auto=") (app (var governance.risk-show) (var auto))
            (lit ",ask=") (app (var governance.risk-show) (var ask-risk))
            (lit ",min-confidence=") (app (var text.from-real) (var confidence))
            (lit ",hash=")
            (app (var hash.to-text) (app (var gm4.policy-hash) (var policy)))
            (lit "}"))))))
   (binding gm4.live-label ()
    (lam
      ((pvar law) (pvar policy) (pvar risk-a) (pvar confidence-a)
        (pvar risk-b) (pvar confidence-b) (pvar verdict-a) (pvar verdict-b))
      (app (var text.join)
        (var law) (lit ": ") (app (var gm4.policy-label) (var policy))
        (lit ", lhs={risk=") (app (var governance.risk-show) (var risk-a))
        (lit ",confidence=") (app (var text.from-real) (var confidence-a))
        (lit ",verdict=") (app (var governance.verdict-show) (var verdict-a))
        (lit "}, rhs={risk=") (app (var governance.risk-show) (var risk-b))
        (lit ",confidence=") (app (var text.from-real) (var confidence-b))
        (lit ",verdict=") (app (var governance.verdict-show) (var verdict-b))
        (lit "}"))))))

(defterm
  ((binding gm4.gen-policy-index ()
    (lam () (app (var sample) (app (var uniform-int) (lit 0) (lit 9)))))
   (binding gm4.gen-confidence-index ()
    (lam () (app (var sample) (app (var uniform-int) (lit 0) (lit 4)))))
   (binding gm4.gen-risk-index ()
    (lam () (app (var sample) (app (var uniform-int) (lit 0) (lit 3)))))
   (binding gm4.gen-bool ()
    (lam () (app (var sample) (app (var bernoulli) (lit 0.5)))))))

; 10 valid threshold pairs x 5 confidence thresholds x 5 observed
; confidences x all ordered risk pairs.  The implication retains every
; generated case, so exhaustive counts remain auditable.
(defterm ((binding gm4-risk-monotonicity ()
  (app (var prop) (lit "risk monotonicity")
    (lam ()
      (let nonrec (pvar policy-index) (app (var gm4.gen-policy-index))
        (let nonrec (pvar threshold-index) (app (var gm4.gen-confidence-index))
          (let nonrec (pvar confidence-index) (app (var gm4.gen-confidence-index))
            (let nonrec (pvar lower-index) (app (var gm4.gen-risk-index))
              (let nonrec (pvar higher-index) (app (var gm4.gen-risk-index))
                (let nonrec (pvar policy)
                  (app (var gm4.live-policy) (var policy-index) (var threshold-index))
                  (let nonrec (pvar confidence)
                    (app (var gm4.confidence-of-index) (var confidence-index))
                    (let nonrec (pvar lower-risk)
                      (app (var gm4.risk-of-index) (var lower-index))
                      (let nonrec (pvar higher-risk)
                        (app (var gm4.risk-of-index) (var higher-index))
                        (let nonrec (pvar lower-verdict)
                          (app (var governance.live-verdict) (var policy)
                            (var lower-risk) (var confidence))
                          (let nonrec (pvar higher-verdict)
                            (app (var governance.live-verdict) (var policy)
                              (var higher-risk) (var confidence))
                            (app (var check.true)
                              (app (var bool.or)
                                (app (var int.lt?) (var higher-index) (var lower-index))
                                (app (var int.lte?)
                                  (app (var gm4.verdict-rank) (var higher-verdict))
                                  (app (var gm4.verdict-rank) (var lower-verdict))))
                              (app (var gm4.live-label) (lit "risk monotonicity")
                                (var policy) (var lower-risk) (var confidence)
                                (var higher-risk) (var confidence) (var lower-verdict)
                                (var higher-verdict)))))))))))))))))))

(defterm ((binding gm4-confidence-monotonicity ()
  (app (var prop) (lit "confidence monotonicity")
    (lam ()
      (let nonrec (pvar policy-index) (app (var gm4.gen-policy-index))
        (let nonrec (pvar risk-index) (app (var gm4.gen-risk-index))
            (let nonrec (pvar lower-index) (app (var gm4.gen-confidence-index))
              (let nonrec (pvar higher-index) (app (var gm4.gen-confidence-index))
                (let nonrec (pvar policy)
                  (app (var gm4.live-policy) (var policy-index) (lit 2))
                  (let nonrec (pvar risk) (app (var gm4.risk-of-index) (var risk-index))
                    (let nonrec (pvar lower-confidence)
                      (app (var gm4.confidence-of-index) (var lower-index))
                      (let nonrec (pvar higher-confidence)
                        (app (var gm4.confidence-of-index) (var higher-index))
                        (let nonrec (pvar lower-verdict)
                          (app (var governance.live-verdict) (var policy) (var risk)
                            (var lower-confidence))
                          (let nonrec (pvar higher-verdict)
                            (app (var governance.live-verdict) (var policy) (var risk)
                              (var higher-confidence))
                            (app (var check.true)
                              (app (var bool.or)
                                (app (var int.lt?) (var higher-index) (var lower-index))
                                (app (var int.lte?)
                                  (app (var gm4.verdict-rank) (var lower-verdict))
                                  (app (var gm4.verdict-rank) (var higher-verdict))))
                              (app (var gm4.live-label)
                                (lit "confidence monotonicity") (var policy) (var risk)
                                (var lower-confidence) (var risk) (var higher-confidence)
                                (var lower-verdict) (var higher-verdict))))))))))))))))))

; All ordered confidence-threshold pairs x all risks x all observed
; confidences under the representative Low/High risk policy.  A higher minimum
; confidence is tighter; exhaustive mode therefore proves the full 500-case
; product independently of risk-threshold tightening.
(defterm ((binding gm4-confidence-threshold-tightening ()
  (app (var prop) (lit "confidence threshold tightening")
    (lam ()
      (let nonrec (pvar tight-threshold-index) (app (var gm4.gen-confidence-index))
        (let nonrec (pvar loose-threshold-index) (app (var gm4.gen-confidence-index))
          (let nonrec (pvar risk-index) (app (var gm4.gen-risk-index))
            (let nonrec (pvar confidence-index) (app (var gm4.gen-confidence-index))
              (let nonrec (pvar tight)
                (app (var gm4.live-policy) (lit 2) (var tight-threshold-index))
                (let nonrec (pvar loose)
                  (app (var gm4.live-policy) (lit 2) (var loose-threshold-index))
                  (let nonrec (pvar risk)
                    (app (var gm4.risk-of-index) (var risk-index))
                    (let nonrec (pvar confidence)
                      (app (var gm4.confidence-of-index) (var confidence-index))
                      (let nonrec (pvar tight-verdict)
                        (app (var governance.live-verdict) (var tight) (var risk)
                          (var confidence))
                        (let nonrec (pvar loose-verdict)
                          (app (var governance.live-verdict) (var loose) (var risk)
                            (var confidence))
                          (let nonrec (pvar is-tightening)
                            (app (var int.lte?) (var loose-threshold-index)
                              (var tight-threshold-index))
                            (app (var check.true)
                              (app (var bool.or)
                                (app (var bool.not) (var is-tightening))
                                (app (var bool.or)
                                  (app (var bool.not)
                                    (app (var gm4.is-allow?) (var tight-verdict)))
                                  (app (var gm4.is-allow?) (var loose-verdict))))
                              (app (var text.join)
                                (lit "confidence threshold tightening: tight=")
                                (app (var gm4.policy-label) (var tight))
                                (lit ",loose=")
                                (app (var gm4.policy-label) (var loose))
                                (lit ",risk=")
                                (app (var governance.risk-show) (var risk))
                                (lit ",confidence=")
                                (app (var text.from-real) (var confidence))
                                (lit ",tight-verdict=")
                                (app (var governance.verdict-show) (var tight-verdict))
                                (lit ",loose-verdict=")
                                (app (var governance.verdict-show)
                                  (var loose-verdict))))))))))))))))))))

(defterm ((binding gm4-forbidden-absorption ()
  (app (var prop) (lit "Forbidden absorption")
    (lam ()
      (let nonrec (pvar policy-index) (app (var gm4.gen-policy-index))
        (let nonrec (pvar threshold-index) (app (var gm4.gen-confidence-index))
          (let nonrec (pvar confidence-index) (app (var gm4.gen-confidence-index))
            (let nonrec (pvar simulator) (app (var gm4.gen-bool))
              (let nonrec (pvar policy)
                (app (var gm4.live-policy) (var policy-index) (var threshold-index))
                (let nonrec (pvar confidence)
                  (app (var gm4.confidence-of-index) (var confidence-index))
                  (let nonrec (pvar live-verdict)
                    (app (var governance.live-verdict) (var policy) (var forbidden)
                      (var confidence))
                    (let nonrec (pvar dry-result)
                      (app (var governance.dry-verdict)
                        (app (var gm4.dry-policy) (var threshold-index))
                        (var forbidden) (var simulator))
                      (app (var check.true)
                        (match (tuple (var live-verdict) (var dry-result))
                          (clause (ptuple (pcon block) (pcon ok (pcon block)))
                            (var true))
                          (clause (pwild) (var false)))
                        (app (var text.join) (lit "Forbidden absorption: ")
                          (app (var gm4.policy-label) (var policy))
                          (lit ",confidence=")
                          (app (var text.from-real) (var confidence))
                          (lit ",simulator=")
                          (app (app (var show.fn) (var bool.show)) (var simulator))
                          (lit ",live=")
                          (app (var governance.verdict-show) (var live-verdict)))))))))))))))))

(defterm ((binding gm4-dry-totality ()
  (app (var prop) (lit "dry-run totality")
    (lam ()
      (let nonrec (pvar threshold-index) (app (var gm4.gen-confidence-index))
        (let nonrec (pvar risk-index) (app (var gm4.gen-risk-index))
          (let nonrec (pvar simulator) (app (var gm4.gen-bool))
            (let nonrec (pvar risk) (app (var gm4.risk-of-index) (var risk-index))
              (let nonrec (pvar result)
                (app (var governance.dry-verdict)
                  (app (var gm4.dry-policy) (var threshold-index))
                  (var risk) (var simulator))
                (app (var check.true)
                  (match (tuple (var risk) (var simulator) (var result))
                    (clause (ptuple (pcon forbidden) (pwild) (pcon ok (pcon block)))
                      (var true))
                    (clause (ptuple (pwild) (pcon true) (pcon ok (pcon simulate)))
                      (var true))
                    (clause
                      (ptuple (pwild) (pcon false) (pcon err (pcon no-simulation)))
                      (var true))
                    (clause (pwild) (var false)))
                  (app (var text.join) (lit "dry-run totality: policy={min-confidence=")
                    (app (var text.from-real)
                      (app (var gm4.confidence-of-index) (var threshold-index)))
                    (lit ",hash=")
                    (app (var hash.to-text)
                      (app (var code.hash)
                        (app (var governance.dry-policy-code)
                          (app (var gm4.dry-policy) (var threshold-index)))))
                    (lit "},risk=") (app (var governance.risk-show) (var risk))
                    (lit ",simulator=")
                    (app (app (var show.fn) (var bool.show)) (var simulator))))))))))))))

(defterm ((binding gm4-policy-tightening ()
  (app (var prop) (lit "policy tightening")
    (lam ()
      (let nonrec (pvar tight-index) (app (var gm4.gen-policy-index))
        (let nonrec (pvar loose-index) (app (var gm4.gen-policy-index))
          (let nonrec (pvar confidence-index) (app (var gm4.gen-confidence-index))
            (let nonrec (pvar risk-index) (app (var gm4.gen-risk-index))
              (let nonrec (pvar tight) (app (var gm4.live-policy) (var tight-index) (lit 2))
                (let nonrec (pvar loose) (app (var gm4.live-policy) (var loose-index) (lit 2))
                  (let nonrec (pvar risk) (app (var gm4.risk-of-index) (var risk-index))
                    (let nonrec (pvar confidence)
                      (app (var gm4.confidence-of-index) (var confidence-index))
                      (let nonrec (pvar tight-verdict)
                        (app (var governance.live-verdict) (var tight) (var risk)
                          (var confidence))
                        (let nonrec (pvar loose-verdict)
                          (app (var governance.live-verdict) (var loose) (var risk)
                            (var confidence))
                          (match
                            (tuple (app (var gm4.thresholds-of-index) (var tight-index))
                              (app (var gm4.thresholds-of-index) (var loose-index)))
                            (clause
                              (ptuple (ptuple (pvar tight-auto) (pvar tight-ask))
                                (ptuple (pvar loose-auto) (pvar loose-ask)))
                              (let nonrec (pvar is-tightening)
                                (app (var bool.and)
                                  (app (var int.lte?)
                                    (app (var governance.risk-rank) (var tight-auto))
                                    (app (var governance.risk-rank) (var loose-auto)))
                                  (app (var int.lte?)
                                    (app (var governance.risk-rank) (var tight-ask))
                                    (app (var governance.risk-rank) (var loose-ask))))
                                (app (var check.true)
                                  (app (var bool.or) (app (var bool.not) (var is-tightening))
                                    (app (var bool.or)
                                      (app (var bool.not)
                                        (app (var gm4.is-allow?) (var tight-verdict)))
                                      (app (var gm4.is-allow?) (var loose-verdict))))
                                  (app (var text.join) (lit "policy tightening: tight=")
                                    (app (var gm4.policy-label) (var tight))
                                    (lit ",loose=") (app (var gm4.policy-label) (var loose))
                                    (lit ",risk=")
                                    (app (var governance.risk-show) (var risk))
                                    (lit ",confidence=")
                                    (app (var text.from-real) (var confidence))
                                    (lit ",tight-verdict=")
                                    (app (var governance.verdict-show) (var tight-verdict))
                                    (lit ",loose-verdict=")
                                    (app (var governance.verdict-show)
                                      (var loose-verdict))))))))))))))))))))))

; Two spellings of the same Code value intentionally differ in whitespace.
(defterm
  ((binding gm4.arguments-canonical () (quote (arguments (lit 7))))
   (binding gm4.arguments-reformatted ()
    (quote
      (arguments
        (lit 7))))
   (binding gm4.preconditions-canonical () (quote (preconditions (lit "fresh"))))
   (binding gm4.make-call ()
    (lam
      ((pvar operation) (pvar arguments) (pvar authority) (pvar summary)
        (pvar preconditions))
      (app (var governance.make-call) (var operation) (var arguments)
        (var authority) (var summary) (var preconditions) (var none))))
   (binding gm4.call-results-equal? ()
    (lam ((pvar left) (pvar right))
      (match (tuple (var left) (var right))
        (clause (ptuple (pcon ok (pvar a)) (pcon ok (pvar b)))
          (app (var governance.hash-eq?) (app (var governance.call-id) (var a))
            (app (var governance.call-id) (var b))))
        (clause (pwild) (var false)))))
   (binding gm4.call-results-differ? ()
    (lam ((pvar left) (pvar right))
      (match (tuple (var left) (var right))
        (clause (ptuple (pcon ok (pvar a)) (pcon ok (pvar b)))
          (app (var bool.not)
            (app (var governance.hash-eq?) (app (var governance.call-id) (var a))
              (app (var governance.call-id) (var b)))))
        (clause (pwild) (var false)))))
   (binding gm4.call-results-label ()
    (lam ((pvar law) (pvar left) (pvar right))
      (match (tuple (var left) (var right))
        (clause (ptuple (pcon ok (pvar a)) (pcon ok (pvar b)))
          (app (var text.join) (var law) (lit ": left-hash=")
            (app (var hash.to-text) (app (var governance.call-id) (var a)))
            (lit ",right-hash=")
            (app (var hash.to-text) (app (var governance.call-id) (var b)))))
        (clause (pwild)
          (app (var text.concat) (var law) (lit ": Call construction failed"))))))))

(defterm ((binding gm4-call-hash-stability ()
  (app (var prop) (lit "Call hash stability")
    (lam ()
      (let nonrec (pvar summary-index) (app (var gm4.gen-confidence-index))
        (let nonrec (pvar base)
          (app (var gm4.make-call) (lit "fs.write")
            (var gm4.arguments-canonical) (var nil) (lit "display summary")
            (var gm4.preconditions-canonical))
          (let nonrec (pvar changed)
            (app (var gm4.make-call) (lit "fs.write")
              (var gm4.arguments-reformatted) (var nil)
              (app (var text.join) (lit "metadata-only-summary-")
                (app (var text.from-int) (var summary-index)))
              (var gm4.preconditions-canonical))
            (app (var check.true)
              (app (var gm4.call-results-equal?) (var base) (var changed))
              (app (var gm4.call-results-label) (lit "Call hash stability")
                (var base) (var changed)))))))))))

(defterm ((binding gm4-call-hash-sensitivity ()
  (app (var prop) (lit "Call hash sensitivity")
    (lam ()
      (let nonrec (pvar field)
        (app (var sample) (app (var uniform-int) (lit 0) (lit 3)))
        (let nonrec (pvar sample-value)
          (app (var sample) (app (var uniform-int) (lit 8) (lit 12)))
          (let nonrec (pvar base)
            (app (var gm4.make-call) (lit "fs.write")
              (var gm4.arguments-canonical) (var nil) (lit "summary")
              (var gm4.preconditions-canonical))
            (let nonrec (pvar changed)
              (match (var field)
                (clause (plit 0)
                  (app (var gm4.make-call) (lit "fs.read")
                    (var gm4.arguments-canonical) (var nil) (lit "summary")
                    (var gm4.preconditions-canonical)))
                (clause (plit 1)
                  (app (var gm4.make-call) (lit "fs.write")
                    (app (var code.form) (lit "arguments")
                      (app (var cons) (app (var code.of-int) (var sample-value)) (var nil)))
                    (var nil) (lit "summary") (var gm4.preconditions-canonical)))
                (clause (plit 2)
                  (app (var gm4.make-call) (lit "fs.write")
                    (var gm4.arguments-canonical)
                    (app (var cons)
                      (app (var governance-effect)
                        (app (var code.hash) (quote (gm4 changed-authority))))
                      (var nil))
                    (lit "summary") (var gm4.preconditions-canonical)))
                (clause (pwild)
                  (app (var gm4.make-call) (lit "fs.write")
                    (var gm4.arguments-canonical) (var nil) (lit "summary")
                    (app (var code.form) (lit "preconditions")
                      (app (var cons) (app (var code.of-int) (var sample-value))
                        (var nil))))))
              (app (var check.true)
                (app (var gm4.call-results-differ?) (var base) (var changed))
                (app (var text.join)
                  (app (var gm4.call-results-label) (lit "Call hash sensitivity")
                    (var base) (var changed))
                  (lit ",field=") (app (var text.from-int) (var field))
                  (lit ",sample=")
                  (app (var text.from-int) (var sample-value)))))))))))))

(defterm
  ((binding gm4.result-is-bound-mismatch? ()
    (lam ((pvar value))
      (match (var value)
        (clause (pcon err (pwild)) (var true))
        (clause (pwild) (var false)))))
   (binding gm4.bound-label ()
    (lam ((pvar kind) (pvar carried) (pvar computed))
      (app (var text.join) (lit "BoundPolicy mismatch: kind=") (var kind)
        (lit ",carried-hash=") (app (var hash.to-text) (var carried))
        (lit ",computed-hash=") (app (var hash.to-text) (var computed)))))))

(defterm ((binding gm4-bound-policy-mismatch ()
  (app (var prop) (lit "BoundPolicy mismatch rejection")
    (lam ()
      (let nonrec (pvar kind)
        (app (var sample) (app (var uniform-int) (lit 0) (lit 2)))
        (let nonrec (pvar policy-index) (app (var gm4.gen-policy-index))
          (let nonrec (pvar threshold-index) (app (var gm4.gen-confidence-index))
            (let nonrec (pvar carried)
              (app (var code.hash) (quote (gm4 deliberately-forged-bound-policy)))
              (match (var kind)
                (clause (plit 0)
                  (let nonrec (pvar policy)
                    (app (var gm4.live-policy) (var policy-index) (var threshold-index))
                    (let nonrec (pvar computed) (app (var gm4.policy-hash) (var policy))
                      (let nonrec (pvar forged)
                        (app (var bound-policy-v0) (var governance-v0) (var carried)
                          (var policy))
                        (app (var check.true)
                          (app (var bool.and)
                            (app (var gm4.result-is-bound-mismatch?)
                              (app (var governance.validate-bound-live-policy) (var forged)))
                            (app (var gm4.result-is-bound-mismatch?)
                              (app (var governance.live-policy-verdict) (var forged)
                                (var low) (lit 1.0))))
                          (app (var gm4.bound-label) (lit "live") (var carried)
                            (var computed)))))))
                (clause (plit 1)
                  (let nonrec (pvar policy) (app (var gm4.dry-policy) (var threshold-index))
                    (let nonrec (pvar computed)
                      (app (var code.hash) (app (var governance.dry-policy-code) (var policy)))
                      (let nonrec (pvar forged)
                        (app (var bound-policy-v0) (var governance-v0) (var carried)
                          (var policy))
                        (app (var check.true)
                          (app (var bool.and)
                            (app (var gm4.result-is-bound-mismatch?)
                              (app (var governance.validate-bound-dry-policy) (var forged)))
                            (app (var gm4.result-is-bound-mismatch?)
                              (app (var governance.dry-policy-verdict) (var forged)
                                (var low) (var true))))
                          (app (var gm4.bound-label) (lit "dry") (var carried)
                            (var computed)))))))
                (clause (pwild)
                  (let nonrec (pvar policy)
                    (app (var gm4.live-policy) (var policy-index) (var threshold-index))
                    (let nonrec (pvar stored) (app (var stored-live) (var policy))
                      (let nonrec (pvar computed)
                        (app (var governance.stored-policy-id) (var stored))
                        (let nonrec (pvar forged)
                          (app (var bound-policy-v0) (var governance-v0) (var carried)
                            (var stored))
                          (app (var check.true)
                            (app (var gm4.result-is-bound-mismatch?)
                              (app (var governance.validate-bound-stored-policy) (var forged)))
                            (app (var gm4.bound-label) (lit "stored") (var carried)
                              (var computed))))))))))))))))))

(defterm
  ((binding gm4.result-is-error? ()
    (lam ((pvar value))
      (match (var value)
        (clause (pcon err (pwild)) (var true))
        (clause (pwild) (var false)))))
   (binding gm4.result-is-verdict? ()
    (lam ((pvar value) (pvar expected))
      (match (var value)
        (clause (pcon ok (pvar actual))
          (app (var governance.int-eq?)
            (app (var gm4.verdict-rank) (var actual))
            (app (var gm4.verdict-rank) (var expected))))
        (clause (pwild) (var false)))))))

; Exact unit edges complement the representative property grid: adjacent
; representable values around 0.5, inclusive 0/1, and every non-finite/out-of-
; range rejection class.
(defterm ((binding gm4-numeric-edges ()
  (app (var case) (lit "exact numeric edges")
    (lam ()
      (let nonrec (pvar policy)
        (app (var gm4.live-policy) (lit 2) (lit 2))
        (let nonrec (pvar bound)
          (app (var bound-policy-v0) (var governance-v0)
            (app (var gm4.policy-hash) (var policy)) (var policy))
          (let nonrec (pwild)
            (app (var check.true)
              (app (var gm4.result-is-verdict?)
                (app (var governance.live-policy-verdict) (var bound) (var low)
                  (lit 0.49999999999999994))
                (var ask))
              (lit "confidence immediately below 0.5 remains Ask"))
            (let nonrec (pwild)
              (app (var check.true)
                (app (var gm4.result-is-verdict?)
                  (app (var governance.live-policy-verdict) (var bound) (var low)
                    (lit 0.5))
                  (var allow))
                (lit "confidence exactly 0.5 is Allow"))
              (let nonrec (pwild)
                (app (var check.true)
                  (app (var gm4.result-is-verdict?)
                    (app (var governance.live-policy-verdict) (var bound) (var low)
                      (lit 0.5000000000000001))
                    (var allow))
                  (lit "confidence immediately above 0.5 is Allow"))
                (let nonrec (pwild)
                  (app (var check.true)
                    (match
                      (tuple
                        (app (var governance.make-live-policy) (var low) (var high)
                          (lit 0.0))
                        (app (var governance.make-live-policy) (var low) (var high)
                          (lit 1.0)))
                      (clause (ptuple (pcon ok (pwild)) (pcon ok (pwild))) (var true))
                      (clause (pwild) (var false)))
                    (lit "confidence endpoints 0 and 1 are inclusive"))
                  (let nonrec (pwild)
                    (app (var check.true)
                      (app (var bool.and)
                        (app (var gm4.result-is-error?)
                          (app (var governance.live-policy-verdict) (var bound) (var low)
                            (lit -0.0000000000000001)))
                        (app (var gm4.result-is-error?)
                          (app (var governance.live-policy-verdict) (var bound) (var low)
                            (lit 1.0000000000000002))))
                      (lit "finite values outside [0,1] are rejected"))
                    (app (var check.true)
                      (app (var bool.and)
                        (app (var gm4.result-is-error?)
                          (app (var governance.live-policy-verdict) (var bound) (var low)
                            (app (var real.div) (lit 0.0) (lit 0.0))))
                        (app (var bool.and)
                          (app (var gm4.result-is-error?)
                            (app (var governance.live-policy-verdict) (var bound) (var low)
                              (app (var real.div) (lit 1.0) (lit 0.0))))
                          (app (var gm4.result-is-error?)
                            (app (var governance.live-policy-verdict) (var bound) (var low)
                              (app (var real.div) (lit -1.0) (lit 0.0))))))
                      (lit "NaN and both infinities are rejected"))))))))))))))
