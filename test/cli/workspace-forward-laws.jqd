; GM.12B: exhaustive runtime attenuation through two real forwarding layers.
; The six finite sample sites have support 4 x 5 x 5 x 5 x 10 x 10 = 50,000.

(defterm
  ((binding gm12b.risk-of-index ()
    (lam ((pvar n))
      (match (var n)
        (clause (plit 0) (var low))
        (clause (plit 1) (var medium))
        (clause (plit 2) (var high))
        (clause (pwild) (var forbidden)))))
   (binding gm12b.confidence-of-index ()
    (lam ((pvar n))
      (match (var n)
        (clause (plit 0) (lit 0.0))
        (clause (plit 1) (lit 0.25))
        (clause (plit 2) (lit 0.5))
        (clause (plit 3) (lit 0.75))
        (clause (pwild) (lit 1.0)))))
   (binding gm12b.thresholds-of-index ()
    (lam ((pvar n))
      (match (var n)
        (clause (plit 0) (tuple (var low) (var low)))
        (clause (plit 1) (tuple (var low) (var medium)))
        (clause (plit 2) (tuple (var low) (var high)))
        (clause (plit 3) (tuple (var low) (var forbidden)))
        (clause (plit 4) (tuple (var medium) (var medium)))
        (clause (plit 5) (tuple (var medium) (var high)))
        (clause (plit 6) (tuple (var medium) (var forbidden)))
        (clause (plit 7) (tuple (var high) (var high)))
        (clause (plit 8) (tuple (var high) (var forbidden)))
        (clause (pwild) (tuple (var forbidden) (var forbidden))))))
   (binding gm12b.policy-pair ()
    (lam ((pvar threshold-index) (pvar confidence-index))
      (match (app (var gm12b.thresholds-of-index) (var threshold-index))
        (clause (ptuple (pvar auto) (pvar ask-risk))
          (match
            (app (var governance.make-live-policy) (var auto) (var ask-risk)
              (app (var gm12b.confidence-of-index) (var confidence-index)))
            (clause (pcon err (pvar message)) (app (var err) (var message)))
            (clause (pcon ok (pvar raw))
              (match (app (var governance.bind-live-policy) (var raw))
                (clause (pcon err (pvar message)) (app (var err) (var message)))
                (clause (pcon ok (pvar bound))
                  (app (var ok) (tuple (var raw) (var bound)))))))))))
   (binding gm12b.executable? ()
    (lam ((pvar verdict))
      (match (var verdict)
        (clause (pcon allow) (var true))
        (clause (pcon ask) (var true))
        (clause (pwild) (var false)))))
   (binding gm12b.policy-label ()
    (lam ((pvar policy))
      (match (var policy)
        (clause
          (pcon live-policy-v0 (pwild) (pvar auto) (pvar ask-risk)
            (pvar min-confidence))
          (app (var text.join)
            (lit "{auto=") (app (var governance.risk-show) (var auto))
            (lit ",ask=") (app (var governance.risk-show) (var ask-risk))
            (lit ",min=") (app (var text.from-real) (var min-confidence))
            (lit "}"))))))
   (binding gm12b.simulators ()
    (app (var workspace.simulators) (var none) (var none) (var none)))))

(defterm ((binding gm12b.run ()
  (lam ((pvar inner-bound) (pvar outer-bound) (pvar risk) (pvar confidence))
    (app (var throw.to-result)
      (lam ()
        (app (var judge.fixed)
          (lam ()
            (app (var audit.in-memory)
              (lam ()
                (app (var governance.with-sequence)
                  (lam ((pvar sequence))
                    (handle
                      (app (var workspace.forward-layer)
                        (var sequence) (var outer-bound) (var gm12b.simulators)
                        (lam ()
                          (app (var workspace.forward-layer)
                            (var sequence) (var inner-bound) (var gm12b.simulators)
                            (lam ()
                              (app (var workspace.read-file)
                                (app (var path-value) (lit "gm12b-sentinel")))))))
                      (ret (pvar value) (var value))
                      (opclause workspace.read-file ((pcon path-value (pvar raw))) k
                        (app (var k) (app (var ok) (var raw))))
                      (opclause governance-approval.ask ((pvar proposal-value)) k
                        (app (var k)
                          (app (var approved)
                            (app (var governance.proposal-id) (var proposal-value))
                            (lit "gm12b-auto-approver")
                            (quote (gm12b-exhaustive-approval)))))))))))
          (app (var governance-assessment-v0) (var governance-v0)
            (var risk) (var confidence) (var nil) (quote (gm12b-exhaustive))))))))))

(defterm ((binding workspace-forward-attenuation ()
  (app (var prop) (lit "nested Workspace policies only attenuate")
    (lam ()
      (let nonrec (pvar inner-threshold-index)
        (app (var sample) (app (var uniform-int) (lit 0) (lit 9)))
        (let nonrec (pvar inner-confidence-index)
          (app (var sample) (app (var uniform-int) (lit 0) (lit 4)))
          (match
            (app (var gm12b.policy-pair) (var inner-threshold-index)
              (var inner-confidence-index))
            (clause (pcon ok (ptuple (pvar inner-policy) (pvar inner-bound)))
              (let nonrec (pvar outer-threshold-index)
                (app (var sample) (app (var uniform-int) (lit 0) (lit 9)))
                (let nonrec (pvar outer-confidence-index)
                  (app (var sample) (app (var uniform-int) (lit 0) (lit 4)))
                  (match
                    (app (var gm12b.policy-pair) (var outer-threshold-index)
                      (var outer-confidence-index))
                    (clause (pcon ok (ptuple (pvar outer-policy) (pvar outer-bound)))
                      (let nonrec (pvar risk-index)
                        (app (var sample) (app (var uniform-int) (lit 0) (lit 3)))
                        (let nonrec (pvar observed-confidence-index)
                          (app (var sample) (app (var uniform-int) (lit 0) (lit 4)))
                          (let nonrec (pvar risk)
                            (app (var gm12b.risk-of-index) (var risk-index))
                            (let nonrec (pvar confidence)
                              (app (var gm12b.confidence-of-index)
                                (var observed-confidence-index))
                              (let nonrec (pvar inner-verdict)
                                (app (var governance.live-verdict) (var inner-policy)
                                  (var risk) (var confidence))
                                (let nonrec (pvar outer-verdict)
                                  (app (var governance.live-verdict) (var outer-policy)
                                    (var risk) (var confidence))
                                  (let nonrec (pvar expected)
                                    (app (var bool.and)
                                      (app (var gm12b.executable?) (var inner-verdict))
                                      (app (var gm12b.executable?) (var outer-verdict)))
                                    (let nonrec (pvar actual)
                                      (match
                                        (app (var gm12b.run) (var inner-bound)
                                          (var outer-bound) (var risk) (var confidence))
                                        (clause
                                          (pcon ok
                                            (ptuple (pcon ok (plit "gm12b-sentinel"))
                                              (pwild)))
                                          (var true))
                                        (clause (pwild) (var false)))
                                      (match (tuple (var expected) (var actual))
                                        (clause (ptuple (pcon true) (pcon true))
                                          (app (var check.true) (var true)
                                            (lit "nested policies only attenuate")))
                                        (clause (ptuple (pcon false) (pcon false))
                                          (app (var check.true) (var true)
                                            (lit "nested policies only attenuate")))
                                        (clause (pwild)
                                          (app (var check.true) (var false)
                                            (app (var text.join)
                                              (lit "inner=")
                                              (app (var gm12b.policy-label)
                                                (var inner-policy))
                                              (lit ",outer=")
                                              (app (var gm12b.policy-label)
                                                (var outer-policy))
                                              (lit ",risk=")
                                              (app (var governance.risk-show) (var risk))
                                              (lit ",confidence=")
                                              (app (var text.from-real) (var confidence))
                                              (lit ",inner-verdict=")
                                              (app (var governance.verdict-show)
                                                (var inner-verdict))
                                              (lit ",outer-verdict=")
                                              (app (var governance.verdict-show)
                                                (var outer-verdict)))))))))))))))
                    (clause (pwild)
                      (app (var check.true) (var false)
                        (lit "valid outer policy construction failed")))))))
            (clause (pwild)
              (app (var check.true) (var false)
                (lit "valid inner policy construction failed")))))))))))
