; GM.15 closed hostile-world matrix. A sampled index selects one of the 349
; reachable call sites. fault.all chooses the immutable ok/fail FaultPlan before
; the plan is executed, so no multi-shot operation occurs inside an affine
; governance or Workspace clause. The resulting proof covers 349 * 2 = 698
; paths without cloning GM.12B's 50,000-policy attenuation lane.

(deftype gm15-state ()
  (con gm15-state-v0
    (field events (tapp (tref list) (tref text)))
    (field raw-actions (tref int))
    (field simulator-attempts (tref int))
    (field evaluated (tref int))
    (field consented (tref int))
    (field completed (tref int))
    (field halted (tref bool))))

(deftype gm15-world ()
  (con gm15-world-v0
    (field flow (tref int))
    (field risk (tref risk))
    (field confidence (tref real))
    (field selected-site (tref int))
    (field sites (tapp (tref list) (tref text)))))

(deftype gm15-fault-plan ()
  (con gm15-fault-plan-v0
    (field world (tref gm15-world))
    (field fail (tref bool))))

(defterm
  ((binding gm15.confidence-of ()
    (lam ((pvar n))
      (match (var n)
        (clause (plit 0) (lit 0.0))
        (clause (plit 1) (lit 0.25))
        (clause (plit 2) (lit 0.5))
        (clause (plit 3) (lit 0.75))
        (clause (pwild) (lit 1.0)))))
   (binding gm15.ask-cell ()
    (lam ((pvar rank))
      (match (app (var lt) (var rank) (lit 2))
        (clause (pcon true)
          (tuple (var low) (app (var gm15.confidence-of) (var rank))))
        (clause (pcon false)
          (match (app (var lt) (var rank) (lit 7))
            (clause (pcon true)
              (tuple (var medium)
                (app (var gm15.confidence-of) (app (var sub) (var rank) (lit 2)))))
            (clause (pcon false)
              (tuple (var high)
                (app (var gm15.confidence-of) (app (var sub) (var rank) (lit 7))))))))))
   (binding gm15.dry-cell ()
    (lam ((pvar rank))
      (tuple
        (match (app (var div) (var rank) (lit 5))
          (clause (plit 0) (var low))
          (clause (plit 1) (var medium))
          (clause (pwild) (var high)))
        (app (var gm15.confidence-of) (app (var mod) (var rank) (lit 5))))))))

; Flow codes: 0 Allow, 1 Approved, 2 Denied, 3 Escalate, 4 Stale,
; 5 live Block, 6 dry Simulate, 7 dry Block.
(defterm ((binding gm15.sites ()
  (lam ((pvar flow))
    (match (var flow)
      (clause (plit 0)
        (app (var cons) (lit "J")
          (app (var cons) (lit "E")
            (app (var cons) (lit "D") (app (var cons) (lit "C") (var nil))))))
      (clause (plit 1)
        (app (var cons) (lit "J")
          (app (var cons) (lit "E")
            (app (var cons) (lit "S")
              (app (var cons) (lit "A")
                (app (var cons) (lit "K")
                  (app (var cons) (lit "D")
                    (app (var cons) (lit "C") (var nil)))))))))
      (clause (plit 2)
        (app (var cons) (lit "J")
          (app (var cons) (lit "E")
            (app (var cons) (lit "S")
              (app (var cons) (lit "A") (app (var cons) (lit "K") (var nil)))))))
      (clause (plit 3)
        (app (var cons) (lit "J")
          (app (var cons) (lit "E")
            (app (var cons) (lit "S")
              (app (var cons) (lit "A") (app (var cons) (lit "K") (var nil)))))))
      (clause (plit 4)
        (app (var cons) (lit "J")
          (app (var cons) (lit "E")
            (app (var cons) (lit "S") (app (var cons) (lit "A") (var nil))))))
      (clause (plit 5)
        (app (var cons) (lit "J") (app (var cons) (lit "E") (var nil))))
      (clause (plit 6)
        (app (var cons) (lit "J")
          (app (var cons) (lit "E")
            (app (var cons) (lit "S") (app (var cons) (lit "C") (var nil))))))
      (clause (pwild)
        (app (var cons) (lit "J")
          (app (var cons) (lit "E") (app (var cons) (lit "C") (var nil))))))))))

(defterm
  ((binding gm15.world ()
    (lam ((pvar flow) (pvar risk-value) (pvar confidence) (pvar selected))
      (app (var gm15-world-v0) (var flow) (var risk-value) (var confidence)
        (var selected) (app (var gm15.sites) (var flow)))))
   (binding gm15.world-of ()
    (lam ((pvar index))
      (match (app (var lt) (var index) (lit 12))
        (clause (pcon true)
          (app (var gm15.world) (lit 0) (var low)
            (app (var gm15.confidence-of)
              (app (var add) (app (var div) (var index) (lit 4)) (lit 2)))
            (app (var mod) (var index) (lit 4))))
        (clause (pcon false)
          (match (app (var lt) (var index) (lit 216))
            (clause (pcon true)
              (let nonrec (pvar offset) (app (var sub) (var index) (lit 12))
                (let nonrec (pvar rank) (app (var div) (var offset) (lit 17))
                  (let nonrec (pvar local) (app (var mod) (var offset) (lit 17))
                    (match (app (var gm15.ask-cell) (var rank))
                      (clause (ptuple (pvar risk-value) (pvar confidence))
                        (match (app (var lt) (var local) (lit 7))
                          (clause (pcon true)
                            (app (var gm15.world) (lit 1) (var risk-value)
                              (var confidence) (var local)))
                          (clause (pcon false)
                            (match (app (var lt) (var local) (lit 12))
                              (clause (pcon true)
                                (app (var gm15.world) (lit 2) (var risk-value)
                                  (var confidence) (app (var sub) (var local) (lit 7))))
                              (clause (pcon false)
                                (app (var gm15.world) (lit 3) (var risk-value)
                                  (var confidence) (app (var sub) (var local) (lit 12)))))))))))))
            (clause (pcon false)
              (match (app (var lt) (var index) (lit 226))
                (clause (pcon true)
                  (let nonrec (pvar offset) (app (var sub) (var index) (lit 216))
                    (app (var gm15.world) (lit 5) (var forbidden)
                      (app (var gm15.confidence-of) (app (var div) (var offset) (lit 2)))
                      (app (var mod) (var offset) (lit 2)))))
                (clause (pcon false)
                  (match (app (var lt) (var index) (lit 286))
                    (clause (pcon true)
                      (let nonrec (pvar offset) (app (var sub) (var index) (lit 226))
                        (match (app (var gm15.dry-cell) (app (var div) (var offset) (lit 4)))
                          (clause (ptuple (pvar risk-value) (pvar confidence))
                            (app (var gm15.world) (lit 6) (var risk-value)
                              (var confidence) (app (var mod) (var offset) (lit 4)))))))
                    (clause (pcon false)
                      (match (app (var lt) (var index) (lit 301))
                        (clause (pcon true)
                          (let nonrec (pvar offset) (app (var sub) (var index) (lit 286))
                            (app (var gm15.world) (lit 7) (var forbidden)
                              (app (var gm15.confidence-of)
                                (app (var div) (var offset) (lit 3)))
                              (app (var mod) (var offset) (lit 3)))))
                        (clause (pcon false)
                          (let nonrec (pvar offset) (app (var sub) (var index) (lit 301))
                            (let nonrec (pvar rank) (app (var div) (var offset) (lit 4))
                              (match (app (var gm15.ask-cell) (var rank))
                                (clause (ptuple (pvar risk-value) (pvar confidence))
                                  (app (var gm15.world) (lit 4) (var risk-value)
                                    (var confidence) (app (var mod) (var offset) (lit 4)))))))))))))))))))))

(defterm
  ((binding gm15.live-verdict ()
    (lam ((pvar risk-value) (pvar confidence))
      (match (app (var governance.make-live-policy) (var low) (var high) (lit 0.5))
        (clause (pcon err (pvar message)) (app (var throw) (var message)))
        (clause (pcon ok (pvar raw))
          (match (app (var governance.bind-live-policy) (var raw))
            (clause (pcon err (pvar message)) (app (var throw) (var message)))
            (clause (pcon ok (pvar bound))
              (match (app (var governance.live-policy-verdict) (var bound)
                (var risk-value) (var confidence))
                (clause (pcon ok (pvar verdict)) (var verdict))
                (clause (pcon err (pvar message)) (app (var throw) (var message))))))))))
   (binding gm15.dry-verdict ()
    (lam ((pvar risk-value))
      (match (app (var governance.make-dry-policy) (lit 0.5))
        (clause (pcon err (pvar message)) (app (var throw) (var message)))
        (clause (pcon ok (pvar raw))
          (match (app (var governance.bind-dry-policy) (var raw))
            (clause (pcon err (pvar message)) (app (var throw) (var message)))
            (clause (pcon ok (pvar bound))
              (match (app (var governance.dry-policy-verdict) (var bound)
                (var risk-value) (var true))
                (clause (pcon ok (pvar verdict)) (var verdict))
                (clause (pcon err (pvar message)) (app (var throw) (var message))))))))))
   (binding gm15.verdict-valid? ()
    (lam ((pvar flow) (pvar risk-value) (pvar confidence))
      (match (var flow)
        (clause (plit 0)
          (match (app (var gm15.live-verdict) (var risk-value) (var confidence))
            (clause (pcon allow) (var true)) (clause (pwild) (var false))))
        (clause (plit 5)
          (match (app (var gm15.live-verdict) (var risk-value) (var confidence))
            (clause (pcon block) (var true)) (clause (pwild) (var false))))
        (clause (plit 6)
          (match (app (var gm15.dry-verdict) (var risk-value))
            (clause (pcon simulate) (var true)) (clause (pwild) (var false))))
        (clause (plit 7)
          (match (app (var gm15.dry-verdict) (var risk-value))
            (clause (pcon block) (var true)) (clause (pwild) (var false))))
        (clause (pwild)
          (match (app (var gm15.live-verdict) (var risk-value) (var confidence))
            (clause (pcon ask) (var true)) (clause (pwild) (var false)))))))))

(defterm
  ((binding gm15.empty-state ()
    (app (var gm15-state-v0) (var nil) (lit 0) (lit 0) (lit 0) (lit 0) (lit 0)
      (var false)))
   (binding gm15.step ()
    (lam ((pvar state-value) (pvar site) (pvar flow) (pvar fail-here))
      (match (var state-value)
        (clause (pcon gm15-state-v0 (pvar events) (pvar raw-actions)
          (pvar simulator-attempts)
          (pvar evaluated-count) (pvar consented-count) (pvar completed-count) (pwild))
          (let nonrec (pvar attempted-raw-actions)
            (match (var site)
              (clause (plit "D") (app (var add) (var raw-actions) (lit 1)))
              (clause (pwild) (var raw-actions)))
            (let nonrec (pvar attempted-simulators)
              (match (var site)
                (clause (plit "S") (app (var add) (var simulator-attempts) (lit 1)))
                (clause (pwild) (var simulator-attempts)))
              (let nonrec (pvar recorded-site)
                (match (tuple (var fail-here) (var site))
                  (clause (ptuple (pcon true) (plit "S")) (lit "S-Err"))
                  (clause (pwild) (var site)))
                (let nonrec (pvar attempted-events)
                  (app (var list.append) (var events)
                    (app (var cons) (var recorded-site) (var nil)))
                  (match (tuple (var fail-here) (var site))
                    (clause (ptuple (pcon true) (plit "S"))
                      (app (var gm15-state-v0) (var attempted-events)
                        (var attempted-raw-actions) (var attempted-simulators)
                        (var evaluated-count) (var consented-count)
                        (var completed-count) (var false)))
                    (clause (ptuple (pcon true) (pwild))
                      (app (var gm15-state-v0) (var attempted-events)
                        (var attempted-raw-actions) (var attempted-simulators)
                        (var evaluated-count) (var consented-count)
                        (var completed-count) (var true)))
                    (clause (pwild)
                      (app (var gm15-state-v0) (var attempted-events)
                        (var attempted-raw-actions) (var attempted-simulators)
                        (match (var site)
                          (clause (plit "E") (lit 1))
                          (clause (pwild) (var evaluated-count)))
                        (match (var site)
                          (clause (plit "K") (lit 1))
                          (clause (pwild) (var consented-count)))
                        (match (var site)
                          (clause (plit "C") (lit 1))
                          (clause (pwild) (var completed-count)))
                        (var false))))))))))))
   (binding gm15.execute-sites ()
    (lam ((pvar sites) (pvar selected) (pvar fail) (pvar flow) (pvar index)
      (pvar state-value))
      (match (var sites)
        (clause (pcon nil) (var state-value))
        (clause (pcon cons (pvar site) (pvar rest))
          (match (var state-value)
            (clause (pcon gm15-state-v0 (pwild) (pwild) (pwild) (pwild) (pwild)
              (pwild) (pcon true)) (var state-value))
            (clause (pwild)
              (app (var gm15.execute-sites) (var rest) (var selected) (var fail)
                (var flow) (app (var add) (var index) (lit 1))
                (app (var gm15.step) (var state-value) (var site) (var flow)
                  (app (var bool.and) (var fail)
                    (app (var eq) (var selected) (var index)))))))))))
   (binding gm15.execute ()
    (lam ((pvar plan))
      (match (var plan)
        (clause (pcon gm15-fault-plan-v0
          (pcon gm15-world-v0 (pvar flow) (pwild) (pwild) (pvar selected) (pvar sites))
          (pvar fail))
          (app (var gm15.execute-sites) (var sites) (var selected) (var fail)
            (var flow) (lit 0) (var gm15.empty-state))))))))

(defterm
  ((binding gm15.count-site ()
    (lam ((pvar target) (pvar xs))
      (match (var xs)
        (clause (pcon nil) (lit 0))
        (clause (pcon cons (pvar site) (pvar rest))
          (app (var add)
            (match (app (var text.eq?) (var site) (var target))
              (clause (pcon true) (lit 1))
              (clause (pcon false) (lit 0)))
            (app (var gm15.count-site) (var target) (var rest)))))))
   (binding gm15.expected-events ()
    (lam ((pvar sites) (pvar selected) (pvar fail) (pvar index))
      (match (var sites)
        (clause (pcon nil) (var nil))
        (clause (pcon cons (pvar site) (pvar rest))
          (match (tuple (var fail) (app (var eq) (var selected) (var index)) (var site))
            (clause (ptuple (pcon true) (pcon true) (plit "S"))
              (app (var cons) (lit "S-Err") (var rest)))
            (clause (ptuple (pcon true) (pcon true) (pwild))
              (app (var cons) (var site) (var nil)))
            (clause (pwild)
              (app (var cons) (var site)
                (app (var gm15.expected-events) (var rest) (var selected)
                  (var fail) (app (var add) (var index) (lit 1))))))))))
   (binding gm15.counts-exact? ()
    (lam ((pvar attempted-events) (pvar successful-events)
      (pvar raw-actions) (pvar simulator-attempts) (pvar evaluated-count)
      (pvar consented-count) (pvar completed-count))
      (let nonrec (pvar expected-simulator-attempts)
        (app (var add)
          (app (var gm15.count-site) (lit "S") (var attempted-events))
          (app (var gm15.count-site) (lit "S-Err") (var attempted-events)))
        (app (var bool.and)
          (app (var eq) (var raw-actions)
            (app (var gm15.count-site) (lit "D") (var attempted-events)))
          (app (var bool.and)
            (app (var eq) (var simulator-attempts) (var expected-simulator-attempts))
            (app (var bool.and)
              (app (var eq) (var evaluated-count)
                (app (var gm15.count-site) (lit "E") (var successful-events)))
              (app (var bool.and)
                (app (var eq) (var consented-count)
                  (app (var gm15.count-site) (lit "K") (var successful-events)))
                (app (var eq) (var completed-count)
                  (app (var gm15.count-site) (lit "C") (var successful-events))))))))))))

(defterm ((binding gm15.plan-valid? ()
  (lam ((pvar plan))
    (match (var plan)
      (clause (pcon gm15-fault-plan-v0
        (pcon gm15-world-v0 (pvar flow) (pvar risk-value) (pvar confidence)
          (pvar selected) (pvar sites)) (pvar fail))
        (match (app (var gm15.execute) (var plan))
          (clause (pcon gm15-state-v0 (pvar events) (pvar raw-actions)
            (pvar simulator-attempts) (pvar evaluated-count) (pvar consented-count)
            (pvar completed-count) (pvar halted))
            (let nonrec (pvar expected-events)
              (app (var gm15.expected-events) (var sites) (var selected) (var fail) (lit 0))
              (let nonrec (pvar successful-events)
                (match (tuple (var fail) (app (var list.nth) (var sites) (var selected)))
                  (clause (ptuple (pcon true) (pcon some (plit "S"))) (var sites))
                  (clause (ptuple (pcon true) (pwild))
                    (app (var list.take) (var sites) (var selected)))
                  (clause (pwild) (var sites)))
                (let nonrec (pvar expected-halted)
                  (match (tuple (var fail) (app (var list.nth) (var sites) (var selected)))
                    (clause (ptuple (pcon true) (pcon some (plit "S"))) (var false))
                    (clause (ptuple (pcon true) (pwild)) (var true))
                    (clause (pwild) (var false)))
                  (app (var bool.and)
                    (app
                      (app (var eq.fn) (app (var eq.for-list) (var text.eq)))
                      (var events) (var expected-events))
                    (app (var bool.and)
                      (app (var gm15.counts-exact?) (var expected-events)
                        (var successful-events) (var raw-actions) (var simulator-attempts)
                        (var evaluated-count) (var consented-count) (var completed-count))
                      (app (var bool.and)
                        (app (app (var eq.fn) (var bool.eq)) (var halted) (var expected-halted))
                        (app (var gm15.verdict-valid?) (var flow)
                          (var risk-value) (var confidence))))))))))))))))

(defterm ((binding governance-fault-path-count ()
  (app (var case) (lit "literal 349-site and 698-path arithmetic")
    (lam ()
      (let nonrec (pwild)
        (app (var check.true)
          (app (var eq)
              (app (var add)
                (app (var add) (lit 12) (lit 204))
                (app (var add) (lit 10)
                (app (var add) (lit 60) (app (var add) (lit 15) (lit 48)))))
            (lit 349))
          (lit "12+204+10+60+15+48 reachable sites = 349"))
        (app (var check.true)
          (app (var eq) (app (var mul) (lit 349) (lit 2)) (lit 698))
          (lit "one ok and one hostile FaultPlan per site = 698 paths"))))))))

(defterm ((binding governance-hostile-matrix ()
  (app (var prop) (lit "immutable FaultPlan covers 698 typed-error/fail-stop paths")
    (lam ()
      (app (var throw.catch)
        (lam ()
          (let nonrec (pvar world)
            (app (var gm15.world-of)
              (app (var sample) (app (var uniform-int) (lit 0) (lit 348))))
            (match
              (app (var fault.all)
                (lam ()
                  (app (var gm15-fault-plan-v0) (var world)
                    (app (var flaky) (lit "gm15.selected-site"))))
                (lit 4))
              (clause (pcon cons (pvar ok-plan) (pcon cons (pvar fail-plan) (pcon nil)))
                (app (var check.true)
                  (app (var bool.and)
                    (app (var gm15.plan-valid?) (var ok-plan))
                    (app (var gm15.plan-valid?) (var fail-plan)))
                  (lit "exact typed S-Err continuation, fail-stop prefix, raw/simulator counts, consent, and completion")))
              (clause (pwild)
                (app (var check.true) (var false)
                  (lit "fault.all must choose exactly ok/fail before execution"))))))
        (lam ((pwild))
          (app (var check.true) (var false)
            (lit "canonical policy fixture construction must remain valid")))))))))
