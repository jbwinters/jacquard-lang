; GM.10 Warp evidence. The property exhaustively crosses every Workspace
; operation, every risk, and missing/success/failing simulator states through
; the real workspace.dry-run handler. A separate case proves a one-site
; fault.all simulator explores both paths before its pure thunk reaches the
; gate.

(defterm
  ((binding gm10-risk ()
    (lam ((pvar index))
      (match (var index)
        (clause (plit 0) (var low))
        (clause (plit 1) (var medium))
        (clause (plit 2) (var high))
        (clause (pwild) (var forbidden)))))
   (binding gm10-policy ()
    (lam ()
      (match (app (var governance.make-dry-policy) (lit 0.5))
        (clause (pcon err (pvar message)) (app (var throw) (var message)))
        (clause (pcon ok (pvar value))
          (match (app (var governance.bind-dry-policy) (var value))
            (clause (pcon ok (pvar bound)) (var bound))
            (clause (pcon err (pvar message)) (app (var throw) (var message))))))))
   (binding gm10-assessment ()
    (lam ((pvar risk-value))
      (app (var governance-assessment-v0) (var governance-v0)
        (var risk-value) (lit 0.75) (var nil) (quote (gm10-warp)))))
   (binding gm10-simulators ()
    (lam ((pvar index))
      (match (var index)
        (clause (plit 0)
          (app (var workspace.simulators) (var none) (var none) (var none)))
        (clause (plit 1)
          (app (var workspace.simulators)
            (app (var some) (lam ((pwild)) (app (var ok) (lit "read"))))
            (app (var some)
              (lam ((pwild) (pwild)) (app (var ok) (tuple))))
            (app (var some)
              (lam ((pwild))
                (app (var ok)
                  (app (var mk-response) (lit 200) (lit "fetch")))))))
        (clause (pwild)
          (app (var workspace.simulators)
            (app (var some)
              (lam ((pwild))
                (app (var err) (app (var driver-failed) (lit "failed")))))
            (app (var some)
              (lam ((pwild) (pwild))
                (app (var err) (app (var driver-failed) (lit "failed")))))
            (app (var some)
              (lam ((pwild))
                (app (var err) (app (var driver-failed) (lit "failed"))))))))))
   (binding gm10-agent ()
    (lam ((pvar operation-index))
      (match (var operation-index)
        (clause (plit 0)
          (app (var workspace.read-file)
            (app (var path-value) (lit "README.md"))))
        (clause (plit 1)
          (match
            (app (var workspace.write-file)
              (app (var path-value) (lit "generated.txt")) (lit "generated"))
            (clause (pcon err (pvar error)) (app (var err) (var error)))
            (clause (pcon ok (ptuple)) (app (var ok) (lit "write")))))
        (clause (pwild)
          (match
            (app (var workspace.fetch)
              (app (var mk-request) (lit "https://example.test/data") (lit "body")))
            (clause (pcon err (pvar error)) (app (var err) (var error)))
            (clause (pcon ok (pwild)) (app (var ok) (lit "fetch"))))))))))

(defterm ((binding gm10-run-with ()
  (lam ((pvar risk-value) (pvar simulators) (pvar operation-index))
    (app (var throw.to-result)
      (lam ()
        (app (var judge.fixed)
          (lam ()
            (app (var audit.in-memory)
              (lam ()
                (app (var workspace.dry-run) (app (var gm10-policy))
                  (var simulators)
                  (lam () (app (var gm10-agent) (var operation-index)))))))
          (app (var gm10-assessment) (var risk-value)))))))))

(defterm ((binding gm10-run ()
  (lam ((pvar risk-index) (pvar simulator-index) (pvar operation-index))
    (app (var gm10-run-with) (app (var gm10-risk) (var risk-index))
      (app (var gm10-simulators) (var simulator-index))
      (var operation-index))))))

(defterm ((binding workspace-dry-run-matrix ()
  (app (var prop) (lit "Workspace dry membrane matrix")
    (lam ()
      (let nonrec (pvar risk-index)
        (app (var sample) (app (var uniform-int) (lit 0) (lit 3)))
        (let nonrec (pvar simulator-index)
          (app (var sample) (app (var uniform-int) (lit 0) (lit 2)))
          (let nonrec (pvar operation-index)
            (app (var sample) (app (var uniform-int) (lit 0) (lit 2)))
            (match
              (app (var gm10-run) (var risk-index)
                (var simulator-index) (var operation-index))
              (clause
                (pcon ok
                  (ptuple (pvar result)
                    (pcon cons
                      (pcon evaluated (pcon governance-v0) (plit 0)
                        (pwild) (pwild) (pwild) (pvar verdict-value))
                      (pcon cons
                        (pcon completed (pcon governance-v0) (plit 1)
                          (pwild) (pvar branch) (pwild))
                        (pcon nil)))))
                (app (var check.true)
                  (match
                    (tuple (var risk-index) (var simulator-index)
                      (var operation-index) (var verdict-value)
                      (var result) (var branch))
                    (clause
                      (ptuple (plit 3) (pwild) (pwild) (pcon block)
                        (pcon err (pcon tool-blocked (pwild))) (plit "blocked"))
                      (var true))
                    (clause
                      (ptuple (pwild) (plit 0) (pwild) (pcon simulate)
                        (pcon err (pcon no-simulation)) (plit "no-simulation"))
                      (var true))
                    (clause
                      (ptuple (pwild) (plit 1) (plit 0) (pcon simulate)
                        (pcon ok (plit "read")) (plit "simulated"))
                      (var true))
                    (clause
                      (ptuple (pwild) (plit 1) (plit 1) (pcon simulate)
                        (pcon ok (plit "write")) (plit "simulated"))
                      (var true))
                    (clause
                      (ptuple (pwild) (plit 1) (pwild) (pcon simulate)
                        (pcon ok (plit "fetch")) (plit "simulated"))
                      (var true))
                    (clause
                      (ptuple (pwild) (pwild) (pwild) (pcon simulate)
                        (pcon err (pcon driver-failed (pwild)))
                        (plit "simulation-failed"))
                      (var true))
                    (clause (pwild) (var false)))
                  (lit "operation, disposition, audit order, and Resume")))
              (clause (pwild)
                (app (var check.true) (var false)
                  (lit "dry membrane must return exactly two audit entries"))))))))))))

(defterm ((binding gm10-fault-all-simulators ()
  (app (var workspace.simulators)
    (app (var some)
      (lam ((pwild))
        (app (var throw.catch)
          (lam ()
            (match
              (app (var test.run)
                (lam ()
                  (match
                    (app (var fault.all)
                      (lam ()
                        (match (app (var flaky) (lit "workspace.read-file"))
                          (clause (pcon false)
                            (app (var ok) (lit "no-fault")))
                          (clause (pcon true)
                            (app (var err)
                              (app (var driver-failed) (lit "injected"))))))
                      (lit 4))
                    (clause
                      (pcon cons (pcon ok (plit "no-fault"))
                        (pcon cons
                          (pcon err (pcon driver-failed (plit "injected")))
                          (pcon nil)))
                      (app (var check.true) (var true) (lit "fault-all:both")))
                    (clause (pwild)
                      (app (var check.true) (var false)
                        (lit "fault-all:both"))))))
              (clause
                (pcon mk-report
                  (pcon cons
                    (ptuple (plit "fault-all:both") (pcon true))
                    (pcon nil))
                  (pcon none))
                (app (var ok) (lit "fault-all:both")))
              (clause (pwild)
                (app (var err)
                  (app (var driver-failed) (lit "bad fault report"))))))
          (lam ((pvar message))
            (app (var err) (app (var driver-failed) (var message)))))))
        (var none) (var none)))))

(defterm ((binding workspace-dry-run-fault-all ()
  (app (var case) (lit "fault.all is discharged before gate-dry")
    (lam ()
      (match
        (app (var gm10-run-with) (var low)
          (var gm10-fault-all-simulators) (lit 0))
        (clause
          (pcon ok
            (ptuple (pcon ok (plit "fault-all:both"))
              (pcon cons
                (pcon evaluated (pcon governance-v0) (plit 0)
                  (pwild) (pwild) (pwild) (pcon simulate))
                (pcon cons
                  (pcon completed (pcon governance-v0) (plit 1)
                    (pwild) (plit "simulated") (pwild))
                  (pcon nil)))))
          (app (var check.true) (var true)
            (lit "both fault paths completed before the pure gate thunk")))
        (clause (pwild)
          (app (var check.true) (var false)
            (lit "fault.all result or audit evidence diverged")))))))))
