; twin of test_handlers.ml test_multishot_choose: the clause resumes the same
; continuation twice and collects both branch values (the ret clause wraps
; each branch as a singleton, the clause appends) -> cons(1, cons(2, nil))
(defeffect choice ((tvar a)) (op choose () (tref bool)))

(handle
  (match (app (var choose))
    (clause (pcon true) (lit 1))
    (clause (pcon false) (lit 2)))
  (ret (pvar x) (app (var cons) (var x) (var nil)))
  (opclause choose () k
    (app (var list.append) (app (var k) (var true)) (app (var k) (var false)))))
