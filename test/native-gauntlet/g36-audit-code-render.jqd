; ET.2: canonical Hash validation and Audit line rendering are direct native parity surface.
(ref #bf5c9d86f11ef2591a2f1b7b9dcbc26342dcb093fce099341ce56e14b75482fb con)

(match
  (app (var hash.parse)
    (lit "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"))
  (clause (pcon ok (pvar hash))
    (app (ref #f15fb6d1d980ba825cf0bdeaab929b149a26bc9b990a6961919a41b54d797426 term)
      (var hash)))
  (clause (pcon err (pvar message)) (var message)))

(match
  (app (var hash.parse)
    (lit "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"))
  (clause (pcon ok (pvar hash))
    (app (var code.render) (app (var code.of-hash) (var hash))))
  (clause (pcon err (pvar message)) (var message)))

; Direct successful result renders the first-class Hash nested in Ok.
(app (var hash.parse)
  (lit "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"))

(app (var hash.parse)
  (lit "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"))

(match
  (app (var hash.parse)
    (lit "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"))
  (clause (pcon ok (pvar hash))
    (app (var emit.collect)
      (lam ()
        (app (var audit.line-log)
          (lam ()
            (let nonrec (pwild)
              (app (var record)
                (app (var completed) (var hash) (lit "native")
                  (app (var outcome-summary) (lit "ok") (var hash)
                    (lit "control:\n\t\x01 utf8:héllo"))))
              (lit 7)))
          (lam ((pvar line))
            (let nonrec (pwild) (app (var emit) (var line))
              (app (var ok) (tuple))))))))
  (clause (pcon err (pvar message))
    (tuple (app (var err) (var message)) (var nil))))
