; one-shot discipline: the clause resumes on one path and aborts on the other
; (min_calls = 0 forces the capturing tier) -> (some(11), none)
(defeffect gate ((tvar a)) (op ask ((tref int)) (tref int)))

(defterm ((binding run-gate ()
  (lam ((pvar n))
    (handle (app (var some) (app (var add) (lit 1) (app (surface-ref-v0 op ask) (var n))))
      (ret (pvar x) (var x))
      (opclause ask ((pvar v)) k
        (match (app (var lt) (var v) (lit 100))
          (clause (pcon true) (app (var k) (app (var add) (var v) (lit 5))))
          (clause (pcon false) (var none)))))))))

(tuple (app (var run-gate) (lit 5)) (app (var run-gate) (lit 500)))
