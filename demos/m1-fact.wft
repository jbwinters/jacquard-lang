; M1 demo 1: factorial — a defterm group plus an expression to run.
(defterm ((binding fact ()
  (lam ((pvar n))
    (match (var n)
      (clause (plit 0) (lit 1))
      (clause (pvar m)
        (app (var mul) (var m)
          (app (var fact) (app (var sub) (var m) (lit 1))))))))))

(app (var fact) (lit 5))
