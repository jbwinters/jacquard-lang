; Warp tests for the product-shaped demos.
;
; This file expects the demo definitions from clarifying-question.jqd,
; agent-dream.jqd, and ambiguity-pipeline.jqd to be loaded before it. The shell
; runner strips each demo at `; --- demo driver ---` so the tests reuse the demo
; definitions without executing their top-level output expressions.

(defterm ((binding demo-ambiguity-click ()
  (app (var case) (lit "date posterior survives until user observe")
    (lam ()
      (let nonrec (pvar table) (app (var date-posterior))
        (let nonrec (pvar clicked) (app (var after-click-apr3))
          (let nonrec (pwild)
            (app (var check.eq) (app (var list.length) (var table)) (lit 3)
              (var int.eq) (var int.show) (lit "three date candidates"))
            (let nonrec (pwild)
              (app (var check.true)
                (app (var real.close?)
                  (app (var dist.mass-of) (var table) (lit "Unknown") (var text.eq))
                  (lit 0.03) (lit 0.000000001))
                (lit "unknown mass preserved"))
              (app (var check.true)
                (app (var real.close?)
                  (app (var dist.mass-of) (var clicked) (lit "schedule-followup")
                    (var text.eq))
                  (lit 1.0) (lit 0.000000001))
                (lit "click conditions the downstream route")))))))))))

(defterm ((binding demo-dream-policy-dist ()
  (app (var case) (lit "dream handler matches explicit world distribution")
    (lam ()
      (app (var check.same-dist)
        (lam ()
          (app (var net.dream)
            (lam () (app (var support-policy)))
            (app (var response-worlds))))
        (lam ()
          (app (var sample)
            (app (var categorical)
              (app (var cons) (app (var mk-pair) (lit "issue-refund") (lit 0.55))
                (app (var cons) (app (var mk-pair) (lit "ask-more") (lit 0.25))
                  (app (var cons) (app (var mk-pair) (lit "fallback-human") (lit 0.20))
                    (var nil)))))))
        (var text.eq) (var text.show) (lit 0.000000001)))))))

(defterm ((binding demo-dream-scripted ()
  (app (var case) (lit "scripted worlds run the same policy")
    (lam ()
      (let nonrec (pwild)
        (app (var check.eq) (app (var scripted-refund)) (lit "issue-refund")
          (var text.eq) (var text.show) (lit "refund world"))
        (app (var check.eq) (app (var scripted-outage)) (lit "fallback-human")
          (var text.eq) (var text.show) (lit "outage world"))))))))

(defterm ((binding demo-voi-policy ()
  (app (var case) (lit "clarifying question asks only when worth it")
    (lam ()
      (let nonrec (pwild)
        (app (var check.eq) (app (var policy) (lit 1.0)) (lit "ask-user")
          (var text.eq) (var text.show) (lit "cheap interruption asks"))
        (let nonrec (pwild)
          (app (var check.eq) (app (var policy) (lit 3.0)) (lit "audit-first")
            (var text.eq) (var text.show) (lit "costly interruption acts"))
          (app (var check.true)
            (app (var real.close?) (app (var question-value)) (lit 2.6)
              (lit 0.000000001))
            (lit "VOI is 2.6")))))))))
