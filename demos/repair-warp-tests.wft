; Warp tests for the repair demo's pure machinery: the mutation walker, the
; patch prior, and the rendered patch. The posterior itself needs the eval
; capability, which Warp's closed {check} row deliberately cannot grant — the
; end-to-end posterior is pinned by the demo driver instead (test/cli/repair.t).
;
; This file expects the definitions from repair.wft, stripped of its driver.

; The overfitting patch the weak posterior discovers: keep the wrong sub,
; divide by 1 instead.
(defterm ((binding overfitting-patch ()
  (quote (lam ((pvar n))
    (app (var div)
      (app (var mul) (var n) (app (var sub) (var n) (lit 1)))
      (lit 1)))))))

(defterm ((binding dup-count ()
  (lam ((pvar codes))
    (match (var codes)
      (clause (pcon nil) (lit 0))
      (clause (pcon cons (pvar c) (pvar rest))
        (app (var add)
          (match (app (var list.contains?) (var rest) (var c) (app (var mk-eq) (var code.eq?)))
            (clause (pcon true) (lit 1))
            (clause (pcon false) (lit 0)))
          (app (var dup-count) (var rest)))))))))

(defterm ((binding mutant-codes ()
  (app (var list.map) (app (var code-mutants) (var buggy-sum-to))
    (lam ((pvar edited))
      (match (var edited)
        (clause (ptuple (pvar m) (pwild)) (var m))))))))

(defterm ((binding repair-mutation-space ()
  (app (var case) (lit "single edits of the shipped program")
    (lam ()
      (let nonrec (pwild)
        (app (var check.eq) (app (var list.length) (var mutant-codes)) (lit 8)
          (var int.eq) (var int.show) (lit "eight single-edit patches"))
        (let nonrec (pwild)
          (app (var check.true)
            (app (var list.contains?) (var mutant-codes) (var intended-fix)
              (app (var mk-eq) (var code.eq?)))
            (lit "the intended fix is a hypothesis"))
          (let nonrec (pwild)
            (app (var check.true)
              (app (var bool.not)
                (app (var list.contains?) (var mutant-codes) (var buggy-sum-to)
                  (app (var mk-eq) (var code.eq?))))
              (lit "no edit is the identity"))
            (app (var check.eq) (app (var dup-count) (var mutant-codes)) (lit 0)
              (var int.eq) (var int.show)
              (lit "patches are pairwise distinct, tally mass cannot merge"))))))))))

(defterm ((binding repair-prior-shape ()
  (app (var case) (lit "prior centers on the shipped program")
    (lam ()
      (let nonrec (pvar table)
        (app (var dist.tally)
          (app (var dist.enumerate)
            (lam () (app (var sample) (app (var patch-prior) (var buggy-sum-to)))))
          (app (var mk-eq) (var code.eq?)))
        (let nonrec (pwild)
          (app (var check.eq) (app (var list.length) (var table)) (lit 9)
            (var int.eq) (var int.show) (lit "nine hypotheses"))
          (let nonrec (pwild)
            (app (var check.true)
              (app (var real.close?)
                (app (var dist.mass-of) (var table) (var buggy-sum-to)
                  (app (var mk-eq) (var code.eq?)))
                (lit 0.2) (lit 0.000000001))
              (lit "keeping the original is the mode"))
            (let nonrec (pwild)
              (app (var check.true)
                (app (var real.close?)
                  (app (var dist.mass-of) (var table) (var intended-fix)
                    (app (var mk-eq) (var code.eq?)))
                  (lit 0.15) (lit 0.000000001))
                (lit "operator swaps weigh 3/20"))
              (app (var check.true)
                (app (var real.close?)
                  (app (var dist.mass-of) (var table) (var overfitting-patch)
                    (app (var mk-eq) (var code.eq?)))
                  (lit 0.05) (lit 0.000000001))
                (lit "literal nudges weigh 1/20")))))))))))

(defterm ((binding repair-patch-rendering ()
  (app (var case) (lit "the patch is one readable divergence")
    (lam ()
      (app (var check.eq)
        (app (var code.diff) (var buggy-sum-to) (var intended-fix))
        (lit "at log/lam[1]/app[1]/app[2]/app[0]/var[0]: - sub + add")
        (var text.eq) (var text.show) (lit "sub becomes add, nothing else moves")))))))

(defterm ((binding repair-prior-support ()
  (app (var prop) (lit "sampled patches stay one edit away")
    (lam ()
      (let nonrec (pvar patch) (app (var sample) (app (var patch-prior) (var buggy-sum-to)))
        (app (var check.true)
          (app (var bool.or)
            (app (var code.eq?) (var patch) (var buggy-sum-to))
            (app (var list.contains?) (var mutant-codes) (var patch)
              (app (var mk-eq) (var code.eq?))))
          (lit "the prior proposes no wild rewrites"))))))))
