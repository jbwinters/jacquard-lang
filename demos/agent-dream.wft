; Agent dream mode: one policy, several worlds.
;
; The policy below performs one Net.fetch. The same policy is run against a
; scripted successful world, a scripted outage, and a probabilistic "dream"
; handler that answers fetch from a discrete world model. The policy code does
; not change; only the handler around Net.fetch changes.

(defterm ((binding response-worlds ()
  (lam ()
    (app (var categorical)
      (app (var cons) (app (var mk-pair) (app (var mk-response) (lit 200) (lit "refund")) (lit 0.55))
        (app (var cons) (app (var mk-pair) (app (var mk-response) (lit 200) (lit "question")) (lit 0.25))
          (app (var cons) (app (var mk-pair) (app (var mk-response) (lit 503) (lit "down")) (lit 0.20))
            (var nil)))))))))

(defterm ((binding support-policy ()
  (lam ()
    (match (app (var fetch) (app (var mk-request) (lit "http://ticket/context") (lit "")))
      (clause (pcon mk-response (pvar status) (pvar body))
        (match (app (var eq) (var status) (lit 200))
          (clause (pcon false) (lit "fallback-human"))
          (clause (pcon true)
            (match (app (var text.contains?) (var body) (lit "refund"))
              (clause (pcon true) (lit "issue-refund"))
              (clause (pcon false) (lit "ask-more")))))))))))

(defterm ((binding net.dream ()
  (lam ((pvar thunk) (pvar world-model))
    (handle (app (var thunk))
      (ret (pvar x) (var x))
      (opclause fetch ((pwild)) k
        (app (var k) (app (var sample) (var world-model)))))))))

(defterm ((binding scripted-refund ()
  (lam ()
    (app (var throw.catch)
      (lam ()
        (app (var net.scripted)
          (lam () (app (var support-policy)))
          (app (var cons) (app (var mk-response) (lit 200) (lit "refund")) (var nil))))
      (lam ((pvar e)) (var e)))))))

(defterm ((binding scripted-outage ()
  (lam ()
    (app (var throw.catch)
      (lam ()
        (app (var net.scripted)
          (lam () (app (var support-policy)))
          (app (var cons) (app (var mk-response) (lit 503) (lit "down")) (var nil))))
      (lam ((pvar e)) (var e)))))))

(defterm ((binding dream-outcomes ()
  (lam ()
    (app (var dist.tally)
      (app (var dist.enumerate)
        (lam ()
          (app (var net.dream)
            (lam () (app (var support-policy)))
            (app (var response-worlds)))))
      (var text.eq))))))

(app (var scripted-refund))
(app (var scripted-outage))
(app (var dream-outcomes))
