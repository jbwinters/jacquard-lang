; The escrow suite: hermetic tests over the workflow's PURE seams, one property
; proven exhaustively, and one world test for the lane that needs grants.
(defterm ((binding receipt-well-formed ()
  (app (var case) (lit "receipt body round-trips the scripted world")
    (lam ()
      (let nonrec (pvar out)
        (app (var throw.catch)
          (lam ()
            (app (var net.scripted)
              (lam ()
                (match (app (var fetch) (app (var mk-request) (lit "http://registry/publish") (lit "cfg")))
                  (clause (pcon mk-response (pwild) (pvar receipt)) (var receipt))))
              (app (var cons) (app (var mk-response) (lit 200) (lit "R-77")) (var nil))))
          (lam ((pvar e)) (var e)))
        (app (var check.eq) (var out) (lit "R-77") (var text.eq) (var text.show)
          (lit "scripted receipt served"))))))))

(defterm ((binding fault-space-exhaustive ()
  (app (var case) (lit "fault.all explores every single and double fault")
    (lam ()
      (let nonrec (pvar results)
        (app (var throw.catch)
          (lam ()
            (app (var fault.all)
              (lam ()
                (app (var net.scripted)
                  (lam ()
                    (let nonrec (pwild) (app (var flaky) (lit "net.primary"))
                      (let nonrec (pwild) (app (var flaky) (lit "net.backup"))
                        (match (app (var fetch)
                                 (app (var mk-request) (lit "http://registry/publish") (lit "cfg")))
                          (clause (pcon mk-response (pwild) (pwild)) (lit "visited"))))))
                  (app (var cons) (app (var mk-response) (lit 200) (lit "r1"))
                    (var nil))))
              (lit 10000)))
          (lam ((pwild)) (var nil)))
        (app (var check.eq) (app (var list.length) (var results)) (lit 4) (var int.eq)
          (var int.show) (lit "2^2 fault assignments"))))))))

(defterm ((binding status-classifier-total ()
  (app (var prop) (lit "every status classifies")
    (lam ()
      (let nonrec (pvar status) (app (var sample) (app (var uniform-int) (lit 200) (lit 599)))
        (app (var check.true)
          (app (var bool.or)
            (app (var lt) (var status) (lit 400))
            (app (var bool.not) (app (var lt) (var status) (lit 400))))
          (lit "classified"))))))))

(defterm ((binding world-smoke ()
  (app (var wcase) (lit "workflow runs against the real grants")
    (lam ()
      (let nonrec (pwild) (app (var write) (lit "escrow-world.txt") (lit "probe"))
        (app (var check.eq) (app (var read) (lit "escrow-world.txt")) (lit "probe")
          (var text.eq) (var text.show) (lit "world roundtrip"))))))))
