# Ring assignment for every named prelude declaration (stdlib SL.9).
# The layering audit (test_rings.ml) asserts via Store.deps that every
# definition's transitive references stay within rings <= its own.
# ring 0: data and pure functions over them; no effects anywhere
# ring 1: pure control effects and their handlers
# ring 2: text/collections/dist (native-backed but world-free)
# ring 3: the world
# --- 01-prim / 02-data (ring 0)
int 0
int-opaque 0
real-opaque 0
text-opaque 0
code-opaque 0
real 0
text 0
code 0
bool 0
true 0
false 0
option 0
some 0
none 0
list 0
cons 0
nil 0
ordering 0
less 0
equal 0
greater 0
# --- 03-effects
eval 3
eval-code 3
abort 1
throw 1
state 1
get 1
put 1
emit 1
console 3
print 3
read-line 3
clock 3
now 3
sleep 3
request 3
mk-request 3
response 3
mk-response 3
net 3
fetch 3
fs 3
read 3
write 3
list-dir 3
prompt 3
mk-prompt 3
infer 3
complete 3
# --- 03-concurrency (ring 2; declarations only, no scheduler/root handler)
task 2
task-result 2
done 2
failed 2
cancelled 2
async 2
async.spawn 2
async.await 2
async.cancel 2
async.yield 2
async.scope 2
