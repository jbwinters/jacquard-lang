(deftype secret-ref ()
  (con secret-ref
    (field name (tref text))
    (field version (tapp (tref option) (tref text)))))

; Secret is deliberately non-derivable. Prelude.load removes this marker
; constructor from the public name index after sealing the declaration.
(deftype secret ()
  (con secret-opaque))

(defeffect secret ()
  (op read once ((tref secret-ref)) (tref secret))
  (op expose once ((tref secret)) (tref text)))
